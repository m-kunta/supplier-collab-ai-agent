# ---------------------------------------------------------------------------
# LLM Provider Selection
# ---------------------------------------------------------------------------
# Which provider to use. Supported: anthropic | openai | google | groq
LLM_PROVIDER=anthropic

# Model override — leave blank to use the provider default:
#   anthropic → claude-3-5-sonnet-latest
#   openai    → gpt-4o-mini
#   google    → gemini-2.5-flash
#   groq      → llama-3.3-70b-versatile
LLM_MODEL=

# ---------------------------------------------------------------------------
# API Keys — fill in the key(s) for the provider(s) you use
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
