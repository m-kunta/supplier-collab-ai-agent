.DS_Store
.env
.venv/
__pycache__/
.pytest_cache/
*.pyc
output/*.md
output/*.docx

# Keep the production landing-zone directory structure without publishing local snapshots
data/inbound/prod/*
!data/inbound/prod/.gitkeep

# Google OAuth credentials — never commit these
config/credentials.json
config/token.json

# Next.js
frontend/.next/
frontend/node_modules/
frontend/package-lock.json
